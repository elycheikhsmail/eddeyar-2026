# .env.test.exemple
# Copier vers .env.test et adapter pour l'environnement de test.
# Cette base est SÉPARÉE de la base de développement.
# Elle est réinitialisée avant chaque session de tests E2E.

DATABASE_URL="mongodb://localhost:27017/rim-ebay-test"
MONGODB_DB_NAME="rim-ebay-test"
NODE_ENV=test
NEXT_PUBLIC_API_URL=http://localhost:3000
SITE_BASE_URL=http://localhost:3000
JWT_SECRET="secret-key-test"
RESEND_API_KEY=re_test_xxx
EMAIL_FROM=test@eddeyar.mr

# Chinguisoft (SMS OTP) — utiliser le mode dev (OTP = 1234 en local)
SMS_OTP_PROVIDER_BASE_URL=http://localhost:3000/ar/p/verification/otp
CHINGUISOFT_VALIDATION_KEY=your_chingu_key
CHINGUISOFT_VALIDATION_TOKEN=your_chingu_token

# TestSprite
TESTSPRITE_API_KEY=""
